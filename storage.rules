rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /capturas/{ownerUid}/{comprovanteId}/{acessoId}/{imgId} {
      allow create: if request.resource.size < 750 * 1024
        && request.resource.contentType.matches('image/jpeg');
      allow update, delete: if false;
    }

    match /capturas/{ownerUid} {
      allow get, list: if isSignedIn() && request.auth.uid == ownerUid;
      allow write: if false;
    }

    match /capturas/{ownerUid}/{allPaths=**} {
      allow get, list: if isSignedIn() && request.auth.uid == ownerUid;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
